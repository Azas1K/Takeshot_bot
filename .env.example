# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# ID супергруппы с включёнными Темами (Topics), куда падают заявки.
# Должно начинаться с -100. Как узнать — смотри README.
ADMIN_GROUP_ID=-1001234567890

# Приветственное сообщение, которое видит клиент при открытии бота
WELCOME_TEXT=Йоу! Хотите заиметь экипу ТШ? Напишите, какой именно товар хотите (можно скинуть скриншот) — и мы с вами свяжемся.

# Автоответ клиенту после его сообщения
AUTO_REPLY_TEXT=Спасибо за обращение! Мы вернёмся к вам, как только сможем 🤝

# Путь к файлу базы данных (можно оставить по умолчанию)
DB_PATH=bot.db
